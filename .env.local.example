# ─────────────────────────────────────────────────────────────
# La Belle (apps/web) — vitrine que lê/grava TUDO no Veltos.
# Fonte única = Veltos. O front não tem banco próprio: usa as RPCs
# públicas (public_salon / public_busy / public_book) do projeto Supabase
# do Veltos. Ver: vault "08 - Plano Adicional - Site .com.br".
# ─────────────────────────────────────────────────────────────

# Supabase do Veltos (mesmo projeto que o sistema da dona usa)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# IMPORTANTE: usar a chave PUBLISHABLE nova (sb_publishable_...).
# As chaves JWT legadas (eyJ...) estão DESATIVADAS neste projeto.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx
# Service role (sb_secret_...): só em rotas de servidor; nunca no cliente.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Salão da La Belle no Veltos — define de qual salão a vitrine puxa
# catálogo, horários e agenda.
NEXT_PUBLIC_SALON_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API publica do Veltos usada pela vitrine La Belle.
NEXT_PUBLIC_VELTOS_API_ORIGIN=https://www.veltos.com.br

# Evolution API (WhatsApp) — opcional, p/ avisos
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
ADMIN_WHATSAPP_PHONE=

# URLs
NEXT_PUBLIC_SITE_URL=https://la-bella-web.vercel.app
