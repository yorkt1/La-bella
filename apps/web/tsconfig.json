{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "ui": [
        "../../packages/ui/src/index.ts"
      ],
      "database": [
        "../../packages/database/src/index.ts"
      ],
      "utils": [
        "../../packages/utils/src/index.ts"
      ]
    },
    "noEmit": true,
    "module": "esnext",
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
